#!/usr/bin/env bash
# Local pre-commit hook for Kaleidoscope.
#
# Mirrors as much of the CI contract (ADR-0005) as can run in seconds,
# so "main is socially always green" stays cheap to maintain under
# pure trunk-based development.
#
# Covers: cargo fmt --check, cargo clippy --all-targets -- -D warnings,
# cargo deny check (Gate 4), cargo test --all-targets --locked
# (Gate 1).
#
# The slower nightly-bound gates (cargo public-api, cargo
# semver-checks) live in pre-push. Mutation testing (Gate 5) remains
# CI-only.
#
# Skip in genuinely justified cases with `git commit --no-verify`.

set -euo pipefail

# Ensure rustup-managed cargo is on PATH. Git invokes hooks under a
# non-interactive shell that does not inherit PATH edits made in
# ~/.zshrc or ~/.bash_profile, so `cargo` may resolve to nothing here
# even though it works fine in the user's terminal. Sourcing
# ~/.cargo/env is rustup's documented one-liner for this and is a
# no-op when rustup is not installed.
if [ -f "$HOME/.cargo/env" ]; then
  # shellcheck source=/dev/null
  . "$HOME/.cargo/env"
fi

red()    { printf '\033[31m%s\033[0m\n' "$*"; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[33m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

bold "[pre-commit] Kaleidoscope local quality gates"

# Step 0: toolchain symmetry check --------------------------------------
# rust-toolchain.toml pins the workspace's compiler version. The pin is
# a rustup convention; only rustup-managed cargo invocations honour it.
# A Homebrew (or other non-rustup) cargo silently runs whatever version
# was installed system-wide, which can mask MSRV mismatches that CI
# will catch on the rustup-controlled runner. This check warns when
# the cargo running the hook does not match the project pin.
pinned_channel=$(grep -E '^channel = ' rust-toolchain.toml 2>/dev/null | head -1 | sed -E 's/.*"([^"]+)".*/\1/')
running_version=$(cargo --version 2>/dev/null | awk '{print $2}')
if [ -n "$pinned_channel" ] && [ -n "$running_version" ]; then
  if [[ "$running_version" == "$pinned_channel"* ]]; then
    : # exact match — fine
  elif [ "$(printf '%s\n' "$pinned_channel" "$running_version" | sort -V | head -1)" = "$pinned_channel" ]; then
    yellow "[warn] cargo $running_version is newer than the project pin ($pinned_channel)"
    yellow "       this hook may pass while CI fails on a tighter MSRV check"
    yellow "       consider switching to rustup so rust-toolchain.toml is honoured"
  else
    red "[fail] cargo $running_version is older than the project pin ($pinned_channel)"
    yellow "       use rustup to honour rust-toolchain.toml"
    exit 1
  fi
fi

# Step 1: cargo fmt --check ---------------------------------------------
echo "→ cargo fmt --all -- --check"
if ! cargo fmt --all -- --check; then
  red "[fail] cargo fmt --check"
  yellow "      run: cargo fmt --all"
  exit 1
fi

# Step 2: cargo clippy --------------------------------------------------
echo "→ cargo clippy --all-targets --locked -- -D warnings"
if ! cargo clippy --all-targets --locked -- -D warnings; then
  red "[fail] cargo clippy"
  exit 1
fi

# Step 3: cargo deny check (Gate 4) -------------------------------------
echo "→ cargo deny --all-features check  (Gate 4)"
if command -v cargo-deny >/dev/null 2>&1; then
  if ! cargo deny --all-features check; then
    red "[fail] cargo deny check"
    exit 1
  fi
else
  yellow "[skip] cargo-deny not installed"
  yellow "      install: cargo install --locked cargo-deny"
fi

# Step 4: cargo test --all-targets --locked (Gate 1) --------------------
# Workspace-wide. Aperture graduated at the close of its v0 DELIVER
# cycle (2026-05-05); both crates ship green tests and the hook
# enforces that on every commit.
echo "→ cargo test --workspace --all-targets --locked  (Gate 1)"
if ! cargo test --workspace --all-targets --locked; then
  red "[fail] cargo test"
  exit 1
fi

green "[pass] all pre-commit gates green"
