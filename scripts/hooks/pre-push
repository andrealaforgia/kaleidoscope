#!/usr/bin/env bash
# Local pre-push hook for Kaleidoscope.
#
# Adds the slower CI gates that need a nightly toolchain. These are
# skipped (with a clear warning) when the relevant tool or toolchain
# is missing — a fresh contributor should not be blocked from pushing
# trivial changes by a missing dev dependency.
#
# Covers: cargo public-api (Gate 2), cargo semver-checks (Gate 3).
#
# Mutation testing (Gate 5) is intentionally not run here. It is
# CI-only by design — local feedback is `cargo test`.
#
# Skip with `git push --no-verify` for genuinely justified cases.

set -euo pipefail

# Ensure rustup-managed cargo is on PATH. Git invokes hooks under a
# non-interactive shell that does not inherit PATH edits made in
# ~/.zshrc or ~/.bash_profile, so `cargo` may resolve to nothing here
# even though it works fine in the user's terminal. Sourcing
# ~/.cargo/env is rustup's documented one-liner for this and is a
# no-op when rustup is not installed.
if [ -f "$HOME/.cargo/env" ]; then
  # shellcheck source=/dev/null
  . "$HOME/.cargo/env"
fi

red()    { printf '\033[31m%s\033[0m\n' "$*"; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[33m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

bold "[pre-push] Kaleidoscope nightly-bound gates"

# Read NIGHTLY_PIN from the CI workflow so local and CI stay in sync.
NIGHTLY_PIN=$(grep -E '^[[:space:]]*NIGHTLY_PIN:' .github/workflows/ci.yml | head -1 | awk '{print $2}')
if [ -z "${NIGHTLY_PIN:-}" ]; then
  yellow "[skip] could not parse NIGHTLY_PIN from .github/workflows/ci.yml"
  exit 0
fi

nightly_available() {
  rustup toolchain list 2>/dev/null | grep -q "$NIGHTLY_PIN"
}

# Step 1: cargo public-api (Gate 2) -------------------------------------
# Covers the harness and Spark. Aperture is NOT graduated to this gate
# (its only library surface is `aperture::testing`, a dev-only seam).
echo "→ cargo public-api  (Gate 2, $NIGHTLY_PIN)"
if command -v cargo-public-api >/dev/null 2>&1 && nightly_available; then
  if git rev-parse --verify origin/main >/dev/null 2>&1; then
    for pkg in otlp-conformance-harness spark; do
      if ! cargo public-api --toolchain "$NIGHTLY_PIN" \
             --diff-git-checkouts origin/main HEAD \
             -p "$pkg" \
             --deny=added --deny=changed --deny=removed; then
        red "[fail] cargo public-api ($pkg)"
        exit 1
      fi
    done
  else
    yellow "[skip] no origin/main yet"
  fi
else
  yellow "[skip] cargo-public-api or $NIGHTLY_PIN missing"
  yellow "      install: cargo install --locked cargo-public-api"
  yellow "               rustup toolchain install $NIGHTLY_PIN"
fi

# Step 2: cargo semver-checks (Gate 3) ----------------------------------
# Covers the harness and Spark. Aperture is NOT graduated (same rationale
# as Gate 2).
echo "→ cargo semver-checks  (Gate 3, $NIGHTLY_PIN)"
if command -v cargo-semver-checks >/dev/null 2>&1 && nightly_available; then
  for pkg in otlp-conformance-harness spark; do
    if ! cargo "+$NIGHTLY_PIN" semver-checks --package "$pkg"; then
      yellow "[note] cargo semver-checks reported issues for $pkg"
      yellow "       (expected on a greenfield crate with no published baseline)"
    fi
  done
else
  yellow "[skip] cargo-semver-checks or $NIGHTLY_PIN missing"
  yellow "      install: cargo install --locked cargo-semver-checks"
fi

green "[pass] all pre-push gates green or skipped with reason"
